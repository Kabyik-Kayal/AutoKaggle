# AutoKaggle Environment Configuration
# ============================================================================
# SECURITY NOTE: This is a TEMPLATE. DO NOT commit .env file to git!
# 
# Instructions:
# 1. Copy this file to .env in the project root
# 2. Fill in your actual API keys
# 3. The .env file will be automatically loaded by python-dotenv
# 4. Never commit .env to version control (.gitignore already includes it)
# ============================================================================

# ==============================================================================
# OPENAI API CONFIGURATION (Optional but Recommended)
# ==============================================================================
# Your OpenAI API key (starts with sk-proj- or sk-)
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here

# OpenAI base URL (Optional)
# Leave blank to use default: https://api.openai.com/v1
# Useful if using OpenAI proxy or alternative endpoint
OPENAI_BASE_URL=https://api.openai.com/v1

# ==============================================================================
# ANTHROPIC API CONFIGURATION (Optional)
# ==============================================================================
# Your Anthropic API key (starts with sk-ant-)
# Get it from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ==============================================================================
# ADDITIONAL SETTINGS (Optional)
# ==============================================================================
# Log level for debug output (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Model selection preference (openai, anthropic, auto)
# auto = automatically select based on model name in framework
LLM_PROVIDER=auto
